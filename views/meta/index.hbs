<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
{{> navbar}}
<main class="container" style="padding-top:2rem">
  <h1>📊 Мета-статистика</h1>
  <p class="page-desc">Актуальна статистика по танках. Оновлюється щодня автоматично.</p>

  <!-- Type filter -->
  <div class="tabs">
    <a href="/meta" class="tab {{#if (eq type "all")}}tab--active{{/if}}">Всі</a>
    <a href="/meta?type=tank" class="tab {{#if (eq type "tank")}}tab--active{{/if}}">🛡️ Танки</a>
  </div>

  <!-- Charts row -->
  <div class="charts-section">
    <div class="chart-card">
      <h3>Winrate по технікам</h3>
      <canvas id="wrChart" height="140"></canvas>
    </div>
    <div class="chart-card">
      <h3>Середній дамаг</h3>
      <canvas id="dmgChart" height="140"></canvas>
    </div>
  </div>

  <!-- Cards grid -->
  <div class="meta-cards-grid">
    {{#each stats}}
    <div class="meta-detail-card">
      <div class="meta-detail-header">
        <span class="meta-entity-icon">🛡️</span>
        <div>
          <div class="meta-entity-name">{{entityName}}</div>
          <div class="meta-entity-type">{{entityType}}</div>
        </div>
        <div class="meta-entity-wr" style="color:{{#if (gt winrate 55)}}#22c55e{{else}}{{#if (lt winrate 49)}}#ef4444{{else}}#f59e0b{{/if}}{{/if}}">
          {{toFixed winrate 1}}%
        </div>
      </div>
      <div class="meta-detail-stats">
        <div class="md-stat">
          <span class="md-val">{{toFixed avgDamage 0}}</span>
          <span class="md-label">Avg DMG</span>
        </div>
        <div class="md-stat">
          <span class="md-val">{{toFixed popularity 1}}%</span>
          <span class="md-label">Популярність</span>
        </div>
      </div>
      <div class="meta-bar-wrap">
        <div class="meta-bar">
          <div class="meta-bar-fill" style="width:{{toFixed popularity 0}}%;background:linear-gradient(90deg,#7c3aed,#06b6d4)"></div>
        </div>
      </div>
    </div>
    {{/each}}
  </div>
</main>
{{> footer}}
<script>
const metaData = {{{chartData}}};
const labels = metaData.map(d => d.name);

const wrCtx = document.getElementById('wrChart').getContext('2d');
new Chart(wrCtx, {
  type: 'bar',
  data: {
    labels,
    datasets: [{
      label: 'Winrate %',
      data: metaData.map(d => d.winrate),
      backgroundColor: metaData.map(d => d.winrate >= 53 ? 'rgba(34,197,94,0.7)' : d.winrate <= 49 ? 'rgba(239,68,68,0.7)' : 'rgba(245,158,11,0.7)'),
      borderRadius: 4
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
      x: { ticks: { color: '#94a3b8', maxRotation: 30 }, grid: { color: '#1e293b' } },
      y: { ticks: { color: '#94a3b8' }, grid: { color: '#1e293b' }, min: 40 }
    }
  }
});

const dmgCtx = document.getElementById('dmgChart').getContext('2d');
new Chart(dmgCtx, {
  type: 'bar',
  data: {
    labels,
    datasets: [{
      label: 'Avg Damage',
      data: metaData.map(d => d.avgDamage),
      backgroundColor: 'rgba(124,58,237,0.7)',
      borderRadius: 4
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
      x: { ticks: { color: '#94a3b8', maxRotation: 30 }, grid: { color: '#1e293b' } },
      y: { ticks: { color: '#94a3b8' }, grid: { color: '#1e293b' } }
    }
  }
});
</script>
<script src="/js/app.js"></script>
</body>
</html>
