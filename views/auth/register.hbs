<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
<div class="auth-container">
  <a href="/" class="auth-logo">⚡ GameStat</a>
  <div class="auth-card">
    <h1 class="auth-title">Реєстрація</h1>
    {{#if error}}
    <div class="alert alert-error">{{error}}</div>
    {{/if}}
    <form action="/auth/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="username">Нікнейм</label>
        <input type="text" id="username" name="username" required placeholder="CoolPlayer" class="form-input" value="{{body.username}}">
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="your@email.com" class="form-input" value="{{body.email}}">
      </div>
      <div class="form-group">
        <label for="password">Пароль</label>
        <input type="password" id="password" name="password" required placeholder="Мінімум 6 символів" class="form-input" minlength="6">
      </div>
      <button type="submit" class="btn-primary btn-full">Зареєструватись</button>
    </form>
    <p class="auth-alt">Вже є акаунт? <a href="/auth/login">Увійти</a></p>
  </div>
</div>
</body>
</html>
